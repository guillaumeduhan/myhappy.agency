---
import LaserFlow from "@/components/LaserFlow";
import "../../globals.css";
import Logo from "../components/Logo.astro";
const title =
  "My Happy Agency — Agence de création web & branding professionnel";
const description =
  "Nous transformons votre image de marque en une expérience digitale impactante. Création de sites web, identité visuelle et stratégie de marque sur mesure.";
const url = "https://myhappyagency.com";
const image = `${url}/og-image.jpg`;

const BRANDS = Array.from({ length: 15 }, (_, i) => `./brands/${i + 1}.svg`);
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- Title & Description -->
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon.ico" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={image} />
    <meta property="og:locale" content="fr_FR" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={image} />
    <meta name="twitter:creator" content="@myhappyagency" />

    <!-- Schema.org / JSON-LD -->
    <script is:inline type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "My Happy Agency",
        "url": "{url}",
        "logo": "{url}/logo.png",
        "description": "{description}",
        "founder": {
          "@type": "Person",
          "name": "Guillaume Duhan"
        },
        "sameAs": [
          "https://www.linkedin.com/company/myhappyagency",
          "https://x.com/blackevilgoblin"
        ],
        "contactPoint": {
          "@type": "ContactPoint",
          "contactType": "customer support",
          "email": "contact@myhappyagency.com"
        }
      }
    </script>

    <!-- Theme -->
    <meta name="theme-color" content="#10b981" />

    <!-- Canonical -->
    <link rel="canonical" href={url} />
  </head>

  <body class="relative bg-black">
    <div
      class="fixed z-0 top-0 left-0 min-[760px]:translate-x-1/3 w-full h-full scale-105"
    >
      <LaserFlow
        client:load
        color="#7566ff"
        wispDensity={1}
        flowSpeed={0.35}
        verticalSizing={2}
        horizontalSizing={0.5}
        fogIntensity={0.45}
        fogScale={0.3}
        wispSpeed={15}
        wispIntensity={5}
        flowStrength={0.25}
        decay={1.1}
        horizontalBeamOffset={0}
        verticalBeamOffset={-0.5}
        style={{ width: "100%", height: "100%" }}
      />
    </div>
    <main class="z-10 text-white my-12">
      <header class="flex flex-col gap-2 w-full z-50 fade-in-up-3">
        <Logo />
        <div class="flex items-center justify-start gap-4 mx-auto z-50">
          <img class="h-8 lg:h-16" src="15588.png" alt="" />
          <p class="text-neutral-500 text-sm lg:text-[20px]">
            100+ clients worldwide <br />
            100M+ visitors reached
          </p>
          <img
            src="15588.png"
            alt=""
            class="transform scale-x-[-1] h-8 lg:h-16"
          />
        </div>
      </header>
      <section class="container grid gap-24 mx-auto text-center py-8 px-4">
        <div class="grid gap-8">
          <div class="grid gap-4">
            <h1
              class="cal-sans text-[36px] md:text-[56px] lg:text-[124px] fade-in-up-1"
              style={{
                lineHeight: 1.16,
              }}
            >
              We build powerful and unforgettable digital experiences.
            </h1>
            <p class="text-neutral-500 text-[30px] fade-in-up-2">
              Websites, interfaces, applications, and systems to help brands
              connect with their audiences.
            </p>
          </div>
          <div class="gap-8 fade-in-up-3 flex mx-auto">
            <a
              href="https://codeg.link/20-min"
              target="_blank"
              rel="noopener noreferrer"
              class="bg-gradient-to-l from-happy-700 to-happy-400 p-[4px] rounded-full"
            >
              <button
                class="flex items-center justify-center gap-2 mx-auto px-4 py-2 lg:px-6 lg:py-4 text-[16px] lg:text-[20px] font-[500] rounded-full bg-gradient-to-r from-happy-700/50 to-black cursor-pointer hover:to-happy-600 transition duration-300"
              >
                <span>20" meet to talk about your project</span>
                <img
                  class="w-8 lg:w-10"
                  src="./gd.png"
                  alt="Guillaume Duhan"
                  loading="lazy"
                />
              </button>
            </a>
          </div>
        </div>
        <div
          class="max-w-5xl w-full mx-auto fade-in-up-3 overflow-hidden relative"
        >
          <div class="max-w-full relative">
            <div class="logo-carousel flex">
              {
                [...BRANDS, ...BRANDS].map((src) => (
                  <div class="flex-shrink-0 flex items-center justify-center px-8 lg:px-12 h-6 lg:h-8">
                    <img
                      src={src}
                      alt="Client logo"
                      class="h-full w-auto max-w-[120px] lg:max-w-[150px] object-contain transition duration-300"
                      loading="lazy"
                    />
                  </div>
                ))
              }
            </div>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
