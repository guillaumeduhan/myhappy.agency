---
interface Item {
  image_url: string;
  title: string;
  created_at: string;
  url: string;
  is_promoted?: boolean;
  is_featured?: boolean;
}

interface Props {
  items: Item[];
}

function timeAgo(date: string): string {
  const now = new Date();
  const past = new Date(date);
  const seconds = Math.floor((now.getTime() - past.getTime()) / 1000);

  const minutes = Math.floor(seconds / 60);
  const hours = Math.floor(minutes / 60);
  const days = Math.floor(hours / 24);
  const weeks = Math.floor(days / 7);
  const months = Math.floor(days / 30);
  const years = Math.floor(days / 365);

  if (years >= 1) return `${years}y ago`;
  if (months >= 1) return `${months}mo ago`;
  if (weeks >= 1) return `${weeks}w ago`;
  if (days >= 1) return `${days}d ago`;
  if (hours >= 1) return `${hours}h ago`;
  if (minutes >= 1) return `${minutes}m ago`;
  return "just now";
}

function withUtm(url: string): string {
  const u = new URL(url);
  u.searchParams.set("utm_source", "myhappyagency");
  return u.toString();
}

const { items } = Astro.props;
---

<section class="max-w-full">
  {items.length === 0 ? (
    <div class="text-center py-16 text-neutral-500">
      <p class="text-lg">No items yet.</p>
      <p class="text-sm mt-2">Add your items in <code class="text-primary-500">data.json</code> to get started.</p>
    </div>
  ) : (
    <ul class="grid gap-2 max-w-full">
      {items.map((a) => (
        <li class="group text-[16px] max-w-full">
          <a
            href={withUtm(a.url)}
            class:list={[
              "flex gap-3 items-center justify-between text-[16px] py-2 px-3 cursor-pointer hover:bg-neutral-800 transition duration-300 overflow-hidden bg-linear-to-r",
              a.is_promoted && "from-transparent to-amber-200 dark:to-amber-600/40",
              a.is_featured && "from-transparent to-green-200 dark:to-green-900/40",
            ]}
            target="_blank"
          >
            <div class="flex items-center gap-3 min-w-0">
              <img
                src={a.image_url}
                alt={a.title}
                class="size-6 rounded-md shrink-0 object-cover"
              />
              <span class="whitespace-nowrap truncate">{a.title}</span>
            </div>
            <div class="flex items-center justify-center gap-2">
              {a.is_promoted ? (
                <span class="text-xs font-medium text-amber-500 border border-amber-500 px-1.5 py-0.5 shrink-0">
                  Promoted
                </span>
              ) : a.is_featured ? (
                <span class="text-xs font-medium text-green-600 border border-green-700 px-1.5 py-0.5 shrink-0">
                  Featured
                </span>
              ) : (
                a.created_at && (
                  <span class="whitespace-nowrap shrink-0 text-neutral-700 group-hover:text-white transition duration-300">
                    {timeAgo(a.created_at)}
                  </span>
                )
              )}
              <span>
              <svg class:list={[
                "transition duration-300",
                a.is_promoted ? "text-amber-500" : a.is_featured ? "text-green-600" : "text-neutral-700 group-hover:text-white",
              ]} xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24"><path fill="currentColor" d="m16 8.4l-8.9 8.9q-.275.275-.7.275t-.7-.275t-.275-.7t.275-.7L14.6 7H7q-.425 0-.712-.288T6 6t.288-.712T7 5h10q.425 0 .713.288T18 6v10q0 .425-.288.713T17 17t-.712-.288T16 16z"/></svg>
              </span>
            </div>
          </a>
        </li>
      ))}
    </ul>
  )}
</section>
