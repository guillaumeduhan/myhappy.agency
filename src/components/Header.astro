---
import DarkMode from "./DarkMode.astro";
import Logo from "./Logo.astro";
---

<header
  class="md:flex md:items-center md:justify-between w-full mx-auto text-center gap-4 my-12"
>
  <div class="flex items-center justify-center gap-2">
    <Logo />
    <p class="truncate whitespace-nowrap">
      My Happy Agency — Création web & branding.
    </p>
    <div class="fixed top-4 right-4">
      <DarkMode />
    </div>
  </div>
  <div class="my-4 md:my-0 flex items-center justify-center gap-4">
    <a
      href="https://codeg.link/20-min"
      target="_blank"
      class="truncate whitespace-nowrap flex items-center gap-2 text-primary-500"
    >
      <span>Prendre rendez-vous</span>
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="32"
        height="32"
        viewBox="0 0 24 24"
        ><!-- Icon from Material Symbols by Google --><path
          fill="currentColor"
          d="m14 18l-1.4-1.45L16.15 13H4v-2h12.15L12.6 7.45L14 6l6 6z"
        ></path></svg
      >
    </a>
  </div>
</header>
